{
  "name": "hha-platform",
  "version": "0.1.0-alpha.2.2",
  "private": true,
  "type": "module",
  "description": "H²A Genesis Platform monorepo bootstrap",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @hha/foundation build && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.32",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  }
}
