{
  "name": "hybrid-home-assistant",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Local-first, AI-native smart home platform.",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
